rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCurrentUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function sessionDoc(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId));
    }

    function isDeviceOwnedByCurrentUser(deviceId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/devices/$(deviceId)).data.userId == request.auth.uid;
    }

    function isSessionParticipantData(sessionData) {
      return isSignedIn()
        && (
          sessionData.cameraUserId == request.auth.uid
          || sessionData.viewerUserId == request.auth.uid
        );
    }

    function isSessionParticipant(sessionId) {
      return isSessionParticipantData(sessionDoc(sessionId).data);
    }

    match /users/{userId} {
      allow read, write: if isCurrentUser(userId);
    }

    match /devices/{deviceId} {
      allow read: if isCurrentUser(resource.data.userId);
      allow create: if isCurrentUser(request.resource.data.userId);
      allow update: if isCurrentUser(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isCurrentUser(resource.data.userId);
    }

    match /sessions/{sessionId} {
      allow create: if isSignedIn()
        && request.resource.data.cameraUserId == request.auth.uid
        && request.resource.data.viewerUserId == null
        && request.resource.data.status == 'waiting'
        && isDeviceOwnedByCurrentUser(request.resource.data.cameraDeviceId);
      allow read, delete: if isSessionParticipantData(resource.data);
      allow update: if isSessionParticipantData(resource.data)
        && request.resource.data.cameraUserId == resource.data.cameraUserId
        && request.resource.data.cameraDeviceId == resource.data.cameraDeviceId
        && (
          request.resource.data.viewerUserId == null
          || request.resource.data.viewerUserId == request.auth.uid
        );
    }

    match /sessions/{sessionId}/candidates/{candidateId} {
      allow read, create: if isSessionParticipant(sessionId);
      allow update, delete: if false;
    }

    match /events/{eventId} {
      allow read: if isCurrentUser(resource.data.userId);
      allow create: if isCurrentUser(request.resource.data.userId);
    }
  }
}
